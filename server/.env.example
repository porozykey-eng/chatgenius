# LeanCloud 配置
# 从 https://leancloud.cn/dashboard 获取
LEANCLOUD_APP_ID=your-app-id
LEANCLOUD_APP_KEY=your-app-key
LEANCLOUD_MASTER_KEY=your-master-key
LEANCLOUD_SERVER_URL=https://avoscloud.com

# 支付宝配置
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-private-key
ALIPAY_PUBLIC_KEY=alipay-public-key
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 服务器配置
PORT=3000

# 管理员配置
# ADMIN_PASSWORD 必须是 bcrypt hash 值
# 使用以下命令生成: node scripts/hash-password.js your-password
ADMIN_PASSWORD=$2a$12$your-bcrypt-hash-here
JWT_SECRET=your-jwt-secret-at-least-32-chars
