# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=chatgenius
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=chatgenius

# 支付宝配置
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-private-key
ALIPAY_PUBLIC_KEY=alipay-public-key
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 微信支付配置
WECHAT_MCHID=your-wechat-merchant-id
WECHAT_API_V3_KEY=your-api-v3-key
WECHAT_SERIAL_NO=your-certificate-serial-no
WECHAT_APPID=your-wechat-appid

# 服务器配置
PORT=3010

# 管理员配置
# ADMIN_PASSWORD 必须是 bcrypt hash 值
# 使用以下命令生成: node -e "require('bcryptjs').hash('your-password', 12).then(h => console.log(h))"
ADMIN_PASSWORD=$2a$12$your-bcrypt-hash-here

# Admin 安全配置
# JWT_SECRET 必须 >= 32 字符，生成命令: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-random-64-char-hex-string-here
# ADMIN_ROUTE 必须配置为随机不可猜测的路径，生成命令: node -e "console.log('/admin-' + require('crypto').randomBytes(6).toString('hex'))"
ADMIN_ROUTE=/admin-your-random-hex-here

# CORS 配置（未配置时将拒绝所有跨域请求）
CORS_ORIGINS=https://chat.sopie.cc

# 邮件服务配置（用于发票通知）
# 以 QQ 邮箱为例：SMTP_HOST=smtp.qq.com, SMTP_PORT=465, SMTP_USER=你的@qq.com, SMTP_PASS=授权码
# 以 163 邮箱为例：SMTP_HOST=smtp.163.com, SMTP_PORT=465, SMTP_USER=你的@163.com, SMTP_PASS=授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-authorization-code
SMTP_FROM=your-email@qq.com

# 环境
NODE_ENV=production

# 许可证 HMAC 密钥（客户端已不使用，仅服务端保留用于可选校验）
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LICENSE_HMAC_SECRET=your-random-64-char-hex-string-here
