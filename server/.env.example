# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=chatgenius
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=chatgenius

# 支付宝配置
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-private-key
ALIPAY_PUBLIC_KEY=alipay-public-key
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 微信支付配置
WECHAT_MCHID=your-wechat-merchant-id
WECHAT_API_V3_KEY=your-api-v3-key
WECHAT_SERIAL_NO=your-certificate-serial-no
WECHAT_APPID=your-wechat-appid

# 服务器配置
PORT=3010

# 管理员配置
# ADMIN_PASSWORD 必须是 bcrypt hash 值
# 使用以下命令生成: node -e "require('bcryptjs').hash('your-password', 12).then(h => console.log(h))"
ADMIN_PASSWORD=$2a$12$your-bcrypt-hash-here

# Admin 安全配置
# JWT_SECRET 必须 >= 32 字符
JWT_SECRET=your-random-64-char-hex-string-here
ADMIN_ROUTE=/admin-cg7x9k

# CORS 配置
CORS_ORIGINS=https://chat.sopie.cc

# 环境
NODE_ENV=production
